/**
 * Checkout Authentication Module
 * Handles: Google OAuth, Email/Password auth, User session management
 * Version: 1.0
 */

import { GAS_CONFIG } from '../config/api.config.js';
import { showSuccess, showError } from '../utils/notifications.js';

// ============================================================================
// AUTH STATE
// ============================================================================

let userAuth = {
  isLoggedIn: false,
  userId: null,
  displayName: '',
  email: '',
  photoURL: '',
  whatsapp: '',
  authMethod: null // 'google' or 'email'
};

// ============================================================================
// INITIALIZATION
// ============================================================================

document.addEventListener('DOMContentLoaded', function() {
  initializeAuth();
  setupAuthTabs();
  setupAuthForms();
  setupTermsCheckbox();
});

function initializeAuth() {
  // Check if user already logged in (from sessionStorage)
  const savedUser = sessionStorage.getItem('sisitus_user');
  if (savedUser) {
    try {
      userAuth = JSON.parse(savedUser);
      showLoggedInState();
    } catch (e) {
      console.error('Error restoring user session:', e);
      sessionStorage.removeItem('sisitus_user');
    }
  }

  // Initialize Google Sign-In
  if (typeof google !== 'undefined') {
    try {
      google.accounts.id.initialize({
        client_id: '1077896753927-npj3ma45dsqrgqmp9bcrioumk6lneo60.apps.googleusercontent.com', // REPLACE THIS
        callback: handleGoogleSignIn,
        auto_select: false
      });

      google.accounts.id.renderButton(
        document.getElementById('google-signin-button'),
        {
          theme: 'outline',
          size: 'large',
          text: 'signup_with',
          locale: 'id'
        }
      );
    } catch (e) {
      console.warn('Google Sign-In not available:', e);
    }
  }
}

function setupAuthTabs() {
  const tabButtons = document.querySelectorAll('.tab-btn');

  tabButtons.forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      
      const tabName = this.dataset.tab;
      const forms = document.querySelectorAll('.auth-form');
      const buttons = document.querySelectorAll('.tab-btn');

      forms.forEach(form => form.classList.remove('active'));
      buttons.forEach(b => b.classList.remove('active'));

      if (tabName === 'register') {
        document.getElementById('register-form').classList.add('active');
      } else {
        document.getElementById('login-form').classList.add('active');
      }
      this.classList.add('active');
    });
  });
}

function setupAuthForms() {
  // Register form
  const registerForm = document.getElementById('register-form');
  if (registerForm) {
    registerForm.addEventListener('submit', handleRegister);
  }

  // Login form
  const loginForm = document.getElementById('login-form');
  if (loginForm) {
    loginForm.addEventListener('submit', handleLogin);
  }
}

function setupTermsCheckbox() {
  const termsCheckbox = document.getElementById('terms-agree');
  const checkoutBtn = document.getElementById('checkout-btn');

  if (termsCheckbox && checkoutBtn) {
    termsCheckbox.addEventListener('change', function() {
      if (userAuth.isLoggedIn && this.checked && userAuth.whatsapp) {
        checkoutBtn.disabled = false;
        document.getElementById('payment-requirement-text').style.display = 'none';
      } else if (!userAuth.isLoggedIn) {
        checkoutBtn.disabled = true;
      } else if (!userAuth.whatsapp) {
        checkoutBtn.disabled = true;
      } else {
        checkoutBtn.disabled = !this.checked;
      }
    });
  }
}

// ============================================================================
// GOOGLE SIGN-IN HANDLER
// ============================================================================

async function handleGoogleSignIn(response) {
  try {
    if (!response.credential) {
      showError('Google Sign-In gagal');
      return;
    }

    // Decode JWT token
    const base64Url = response.credential.split('.')[1];
    const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
    const jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {
      return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
    }).join(''));

    const decodedToken = JSON.parse(jsonPayload);

    // Register or login user
    userAuth = {
      isLoggedIn: true,
      userId: `GOOG-${decodedToken.sub}`,
      displayName: decodedToken.name,
      email: decodedToken.email,
      photoURL: decodedToken.picture,
      whatsapp: '',
      authMethod: 'google'
    };

    // Save to backend
    const params = new URLSearchParams({
      action: 'registerUser',
      email: userAuth.email,
      displayName: userAuth.displayName,
      password: '', // Empty for Google auth
      photoURL: userAuth.photoURL,
      authMethod: 'google'
    });

    const result = await fetch(`${GAS_CONFIG.URL}?${params}`).then(r => r.json());

    if (result.success) {
      userAuth.userId = result.userId;
      userAuth.whatsapp = result.whatsapp || '';

      // Save to sessionStorage
      sessionStorage.setItem('sisitus_user', JSON.stringify(userAuth));

      showSuccess('Login dengan Google berhasil!');
      showLoggedInState();
    } else if (result.message && result.message.includes('sudah terdaftar')) {
      // User exists, do lookup
      const lookupResult = await fetch(`${GAS_CONFIG.URL}?action=getUserByEmail&email=${encodeURIComponent(userAuth.email)}`)
        .then(r => r.json());

      if (lookupResult.success) {
        userAuth.userId = lookupResult.user.userId;
        userAuth.whatsapp = lookupResult.user.whatsapp;
        sessionStorage.setItem('sisitus_user', JSON.stringify(userAuth));
        showSuccess('Selamat datang kembali!');
        showLoggedInState();
      }
    } else {
      showError(result.message || 'Gagal melakukan registrasi');
    }
  } catch (error) {
    console.error('Google Sign-In error:', error);
    showError('Terjadi kesalahan saat login');
  }
}

// ============================================================================
// REGISTER HANDLER
// ============================================================================

async function handleRegister(e) {
  e.preventDefault();

  const formData = new FormData(this);
  const displayName = formData.get('displayName').trim();
  const email = formData.get('email').trim();
  const password = formData.get('password');
  const passwordConfirm = formData.get('passwordConfirm');
  const whatsapp = formData.get('whatsapp').trim();

  // Validation
  const errors = [];

  if (displayName.length < 3) {
    errors.push('Nama minimal 3 karakter');
  }

  if (!isValidEmail(email)) {
    errors.push('Email tidak valid');
  }

  if (password.length < 6) {
    errors.push('Password minimal 6 karakter');
  }

  if (password !== passwordConfirm) {
    errors.push('Password tidak cocok');
  }

  if (!isValidWhatsApp(whatsapp)) {
    errors.push('Nomor WhatsApp tidak valid (format: 08xxxxxxxxxx)');
  }

  if (errors.length > 0) {
    showError(errors.join('\n'));
    return;
  }

  try {
    // Show loading state
    const submitBtn = this.querySelector('button[type="submit"]');
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Mendaftar...';
    submitBtn.disabled = true;

    // Register user
    const params = new URLSearchParams({
      action: 'registerUser',
      email: email,
      displayName: displayName,
      password: btoa(password), // Simple base64 encoding (use bcrypt in production)
      whatsapp: whatsapp,
      authMethod: 'email'
    });

    const result = await fetch(`${GAS_CONFIG.URL}?${params}`).then(r => r.json());

    if (result.success) {
      userAuth = {
        isLoggedIn: false, // Will be true after email verification
        userId: result.userId,
        displayName: displayName,
        email: email,
        photoURL: '',
        whatsapp: whatsapp,
        authMethod: 'email'
      };

      sessionStorage.setItem('sisitus_user_pending', JSON.stringify(userAuth));

      showSuccess('Pendaftaran berhasil! Silakan check email untuk verifikasi.');

      // Reset form
      this.reset();

      // Redirect to verify email page (optional)
      setTimeout(() => {
        alert('Link verifikasi telah dikirim ke email ' + email);
      }, 1000);
    } else {
      showError(result.message || 'Gagal mendaftar');
    }

    submitBtn.textContent = originalText;
    submitBtn.disabled = false;
  } catch (error) {
    console.error('Register error:', error);
    showError('Terjadi kesalahan saat mendaftar');
  }
}

// ============================================================================
// LOGIN HANDLER
// ============================================================================

async function handleLogin(e) {
  e.preventDefault();

  const formData = new FormData(this);
  const email = formData.get('email').trim();
  const password = formData.get('password');

  // Validation
  if (!isValidEmail(email)) {
    showError('Email tidak valid');
    return;
  }

  if (password.length < 6) {
    showError('Password minimal 6 karakter');
    return;
  }

  try {
    // Show loading state
    const submitBtn = this.querySelector('button[type="submit"]');
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Login...';
    submitBtn.disabled = true;

    // Login user
    const params = new URLSearchParams({
      action: 'loginUser',
      email: email,
      password: btoa(password)
    });

    const result = await fetch(`${GAS_CONFIG.URL}?${params}`).then(r => r.json());

    if (result.success) {
      userAuth = {
        isLoggedIn: true,
        userId: result.userId,
        displayName: result.displayName,
        email: result.email,
        photoURL: result.photoURL || '',
        whatsapp: result.whatsapp || '',
        authMethod: 'email'
      };

      sessionStorage.setItem('sisitus_user', JSON.stringify(userAuth));

      showSuccess('Login berhasil! Selamat datang.');
      showLoggedInState();

      // Reset form
      this.reset();
    } else {
      showError(result.message || 'Email atau password salah');
    }

    submitBtn.textContent = originalText;
    submitBtn.disabled = false;
  } catch (error) {
    console.error('Login error:', error);
    showError('Terjadi kesalahan saat login');
  }
}

// ============================================================================
// LOGGED IN STATE DISPLAY
// ============================================================================

function showLoggedInState() {
  const notLoggedInSection = document.getElementById('auth-section-not-logged-in');
  const loggedInSection = document.getElementById('auth-section-logged-in');
  const checkoutBtn = document.getElementById('checkout-btn');
  const paymentRequirement = document.getElementById('payment-requirement-text');

  if (notLoggedInSection) notLoggedInSection.style.display = 'none';
  if (loggedInSection) {
    loggedInSection.style.display = 'block';

    // Populate user info
    const profilePic = document.getElementById('user-profile-pic');
    const displayName = document.getElementById('user-display-name');
    const userEmail = document.getElementById('user-email');
    const whatsappInput = document.getElementById('user-whatsapp');

    if (profilePic) profilePic.src = userAuth.photoURL || 'https://via.placeholder.com/60';
    if (displayName) displayName.textContent = userAuth.displayName;
    if (userEmail) userEmail.textContent = userAuth.email;
    if (whatsappInput) whatsappInput.value = userAuth.whatsapp;
  }

  // Enable payment button if all conditions met
  if (checkoutBtn && paymentRequirement) {
    const termsCheckbox = document.getElementById('terms-agree');
    if (userAuth.whatsapp && termsCheckbox && termsCheckbox.checked) {
      checkoutBtn.disabled = false;
      paymentRequirement.style.display = 'none';
    } else {
      checkoutBtn.disabled = true;
      if (!userAuth.whatsapp) {
        paymentRequirement.textContent = 'Silakan isi nomor WhatsApp';
        paymentRequirement.style.display = 'block';
      } else if (!termsCheckbox || !termsCheckbox.checked) {
        paymentRequirement.textContent = 'Silakan setujui Syarat & Ketentuan';
        paymentRequirement.style.display = 'block';
      }
    }
  }
}

// ============================================================================
// LOGOUT HANDLER
// ============================================================================

function handleLogout() {
  if (!confirm('Apakah Anda yakin ingin logout?')) {
    return;
  }

  userAuth = {
    isLoggedIn: false,
    userId: null,
    displayName: '',
    email: '',
    photoURL: '',
    whatsapp: '',
    authMethod: null
  };

  sessionStorage.removeItem('sisitus_user');
  sessionStorage.removeItem('sisitus_user_pending');

  // Reset UI
  const notLoggedInSection = document.getElementById('auth-section-not-logged-in');
  const loggedInSection = document.getElementById('auth-section-logged-in');

  if (notLoggedInSection) notLoggedInSection.style.display = 'block';
  if (loggedInSection) loggedInSection.style.display = 'none';

  // Reset forms
  const registerForm = document.getElementById('register-form');
  const loginForm = document.getElementById('login-form');
  if (registerForm) registerForm.reset();
  if (loginForm) loginForm.reset();

  // Reset checkout button
  const checkoutBtn = document.getElementById('checkout-btn');
  if (checkoutBtn) checkoutBtn.disabled = true;

  showSuccess('Logout berhasil');
}

// ============================================================================
// UPDATE WHATSAPP
// ============================================================================

async function updateUserWhatsApp() {
  const whatsappInput = document.getElementById('user-whatsapp');
  const whatsapp = whatsappInput.value.trim();

  if (!whatsapp) {
    showError('Nomor WhatsApp tidak boleh kosong');
    return;
  }

  if (!isValidWhatsApp(whatsapp)) {
    showError('Format WhatsApp tidak valid (08xxxxxxxxxx)');
    return;
  }

  try {
    const params = new URLSearchParams({
      action: 'updateUserWhatsApp',
      userId: userAuth.userId,
      whatsapp: whatsapp
    });

    const result = await fetch(`${GAS_CONFIG.URL}?${params}`).then(r => r.json());

    if (result.success) {
      userAuth.whatsapp = whatsapp;
      sessionStorage.setItem('sisitus_user', JSON.stringify(userAuth));

      showSuccess('Nomor WhatsApp berhasil diperbarui');

      // Re-enable checkout button if all conditions met
      showLoggedInState();
    } else {
      showError(result.message || 'Gagal memperbarui WhatsApp');
    }
  } catch (error) {
    console.error('Update WhatsApp error:', error);
    showError('Terjadi kesalahan saat memperbarui WhatsApp');
  }
}

// ============================================================================
// VALIDATION HELPERS
// ============================================================================

function isValidEmail(email) {
  const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  return regex.test(email);
}

function isValidWhatsApp(phone) {
  // Format: 08xxxxxxxxxx (minimum 10 digits, max 13)
  return /^08\d{8,11}$/.test(phone.replace(/\D/g, ''));
}

