/**
 * Order History List Page - Load and display user orders
 */

import { GAS_CONFIG } from '../config/api.config.js';

let allOrders = [];
let filteredOrders = [];
let currentFilter = 'all';

// ============================================================================
// INITIALIZE
// ============================================================================

document.addEventListener('DOMContentLoaded', async () => {
  // Check authentication
  if (!userAuth || !userAuth.isLoggedIn) {
    window.location.href = '/verify-email.html';
    return;
  }

  // Load orders
  await loadOrders();

  // Setup event listeners
  setupFilterButtons();
});

// ============================================================================
// LOAD ORDERS
// ============================================================================

async function loadOrders() {
  try {
    showLoadingState();

    const params = new URLSearchParams({
      action: 'getUserOrders',
      userId: userAuth.userId
    });

    const result = await fetch(`\$\{GAS_CONFIG.URL\}?${params}`).then(r => r.json());

    if (result.success && result.orders) {
      allOrders = result.orders;
      filteredOrders = allOrders;
      displayOrders();
      updateStatistics();
      hideLoadingState();
    } else {
      showEmptyState();
    }
  } catch (error) {
    console.error('Error loading orders:', error);
    showErrorState('Gagal memuat pesanan. Silakan coba lagi.');
  }
}

// ============================================================================
// FILTER ORDERS
// ============================================================================

function setupFilterButtons() {
  const filterButtons = document.querySelectorAll('.filter-btn');
  
  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove active class from all buttons
      filterButtons.forEach(b => b.classList.remove('active'));
      
      // Add active class to clicked button
      btn.classList.add('active');
      
      // Update filter
      currentFilter = btn.dataset.filter;
      applyFilter();
    });
  });
}

function applyFilter() {
  if (currentFilter === 'all') {
    filteredOrders = allOrders;
  } else {
    filteredOrders = allOrders.filter(order => {
      return order.paymentStatus.toLowerCase() === currentFilter.toLowerCase();
    });
  }

  displayOrders();
}

// ============================================================================
// DISPLAY ORDERS
// ============================================================================

function displayOrders() {
  const tableBody = document.getElementById('ordersTableBody');
  const container = document.getElementById('ordersContainer');
  const orderCount = document.querySelector('.order-count');

  if (filteredOrders.length === 0) {
    showEmptyState();
    return;
  }

  // Clear existing rows
  tableBody.innerHTML = '';

  // Add rows
  filteredOrders.forEach(order => {
    const row = document.createElement('tr');
    
    const statusClass = getStatusClass(order.paymentStatus);
    const formattedDate = Formatting.formatDate(order.createdAt);
    const formattedTotal = Formatting.formatRupiah(order.total);

    row.innerHTML = `
      <td class="order-id">${order.orderId}</td>
      <td>${order.domain || '-'}</td>
      <td>${order.packageName || '-'}</td>
      <td>${formattedTotal}</td>
      <td>${formattedDate}</td>
      <td>
        <span class="status-badge ${statusClass}">
          ${formatStatus(order.paymentStatus)}
        </span>
      </td>
      <td>
        <a href="/orders/detail/?orderId=${order.orderId}" class="action-btn">
          <i class="fas fa-eye"></i> Lihat
        </a>
      </td>
    `;

    tableBody.appendChild(row);
  });

  // Update order count
  orderCount.textContent = `${filteredOrders.length} pesanan`;

  // Show container
  container.style.display = 'block';
  document.getElementById('emptyState').style.display = 'none';
  document.getElementById('errorState').style.display = 'none';
}

// ============================================================================
// STATISTICS
// ============================================================================

function updateStatistics() {
  // Total orders
  const totalOrders = allOrders.length;
  document.getElementById('statTotalOrders').textContent = totalOrders;

  // Total paid
  const paidOrders = allOrders.filter(o => 
    o.paymentStatus.toLowerCase() === 'settlement' || 
    o.paymentStatus.toLowerCase() === 'paid'
  );
  const totalPaid = paidOrders.reduce((sum, o) => sum + (parseFloat(o.total) || 0), 0);
  document.getElementById('statTotalPaid').textContent = Formatting.formatRupiah(totalPaid);

  // Pending orders count
  const pendingOrders = allOrders.filter(o => 
    o.paymentStatus.toLowerCase() === 'pending'
  );
  document.getElementById('statPendingOrders').textContent = pendingOrders.length;

  // Last update
  if (allOrders.length > 0) {
    const lastOrder = allOrders[0];
    const lastDate = new Date(lastOrder.createdAt);
    const timeAgo = getTimeAgo(lastDate);
    document.getElementById('statLastUpdate').textContent = timeAgo;
  }
}

// ============================================================================
// UI STATES
// ============================================================================

function showLoadingState() {
  document.getElementById('loadingState').style.display = 'block';
  document.getElementById('ordersContainer').style.display = 'none';
  document.getElementById('emptyState').style.display = 'none';
  document.getElementById('errorState').style.display = 'none';
}

function showEmptyState() {
  document.getElementById('loadingState').style.display = 'none';
  document.getElementById('ordersContainer').style.display = 'none';
  document.getElementById('emptyState').style.display = 'block';
  document.getElementById('errorState').style.display = 'none';
}

function showErrorState(message = 'Terjadi kesalahan saat memuat data') {
  document.getElementById('loadingState').style.display = 'none';
  document.getElementById('ordersContainer').style.display = 'none';
  document.getElementById('emptyState').style.display = 'none';
  document.getElementById('errorState').style.display = 'block';
  document.getElementById('errorMessage').textContent = message;
}

function hideLoadingState() {
  document.getElementById('loadingState').style.display = 'none';
}

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

function getStatusClass(status) {
  const s = status.toLowerCase();
  if (s === 'settlement' || s === 'paid') return 'settlement';
  if (s === 'pending') return 'pending';
  if (s === 'expired') return 'expired';
  if (s === 'denied') return 'denied';
  return 'pending';
}

function formatStatus(status) {
  const s = status.toLowerCase();
  if (s === 'settlement' || s === 'paid') return 'Terbayar';
  if (s === 'pending') return 'Pending';
  if (s === 'expired') return 'Kadaluarsa';
  if (s === 'denied') return 'Ditolak';
  return status;
}

// formatDate and formatRupiah moved to /assets/js/utils/formatting.js
// Use Formatting.formatDate() and Formatting.formatRupiah() instead

function getTimeAgo(date) {
  const now = new Date();
  const seconds = Math.floor((now - date) / 1000);
  
  if (seconds < 60) return 'Baru saja';
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m yang lalu`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h yang lalu`;
  const days = Math.floor(hours / 24);
  if (days < 7) return `${days}d yang lalu`;
  const weeks = Math.floor(days / 7);
  if (weeks < 4) return `${weeks}w yang lalu`;
  
  return formatDate(date);
}

function logout() {
  if (confirm('Apakah Anda yakin ingin logout?')) {
    sessionStorage.removeItem('userAuth');
    userAuth = null;
    window.location.href = '/';
  }
}

// Export for global use
window.applyFilter = applyFilter;
window.logout = logout;
