/**
 * Order Detail Page - Display single order details
 */

import { GAS_CONFIG } from '../config/api.config.js';

let currentOrder = null;

// ============================================================================
// INITIALIZE
// ============================================================================

document.addEventListener('DOMContentLoaded', async () => {
  // Check authentication
  if (!userAuth || !userAuth.isLoggedIn) {
    window.location.href = '/verify-email.html';
    return;
  }

  // Get order ID from URL
  const orderId = getOrderIdFromURL();
  if (!orderId) {
    showErrorState('Order ID tidak ditemukan');
    return;
  }

  // Load order detail
  await loadOrderDetail(orderId);
});

// ============================================================================
// GET ORDER ID FROM URL
// ============================================================================

function getOrderIdFromURL() {
  const params = new URLSearchParams(window.location.search);
  return params.get('orderId');
}

// ============================================================================
// LOAD ORDER DETAIL
// ============================================================================

async function loadOrderDetail(orderId) {
  try {
    showLoadingState();

    const params = new URLSearchParams({
      action: 'getOrderDetail',
      orderId: orderId,
      userId: userAuth.userId
    });

    const result = await fetch(`\$\{GAS_CONFIG.URL\}?${params}`).then(r => r.json());

    if (result.success && result.order) {
      currentOrder = result.order;
      displayOrderDetail();
      hideLoadingState();
    } else {
      showErrorState(result.message || 'Pesanan tidak ditemukan');
    }
  } catch (error) {
    console.error('Error loading order detail:', error);
    showErrorState('Terjadi kesalahan saat memuat detail pesanan');
  }
}

// ============================================================================
// DISPLAY ORDER DETAIL
// ============================================================================

function displayOrderDetail() {
  const order = currentOrder;

  // Order Header
  document.getElementById('orderIdDisplay').textContent = order.orderId;
  document.getElementById('orderDateDisplay').textContent = Formatting.formatDate(order.createdAt);

  // Status Badge
  const statusBadge = document.getElementById('statusBadge');
  const statusClass = getStatusClass(order.paymentStatus);
  statusBadge.className = `status-badge ${statusClass}`;
  statusBadge.textContent = formatStatus(order.paymentStatus);

  // Domain Section
  document.getElementById('domainName').textContent = order.domain || '-';
  document.getElementById('domainDuration').textContent = order.domainDuration ? `${order.domainDuration} tahun` : '-';
  document.getElementById('domainPrice').textContent = Formatting.formatRupiah(order.domainPrice || 0);

  // Package Section
  document.getElementById('packageName').textContent = order.packageName || '-';
  document.getElementById('packagePrice').textContent = Formatting.formatRupiah(order.packagePrice || 0);

  // Addons Section
  displayAddons(order.addons);

  // Price Summary
  document.getElementById('subtotal').textContent = Formatting.formatRupiah(order.subtotal || 0);
  document.getElementById('ppn').textContent = Formatting.formatRupiah(order.ppn || 0);

  // Discount (if any)
  if (order.discount && order.discount > 0) {
    document.getElementById('discountRow').style.display = 'flex';
    document.getElementById('discount').textContent = `-${Formatting.formatRupiah(order.discount)}`;
    if (order.promoCode) {
      document.getElementById('promoCodeDisplay').textContent = `(${order.promoCode})`;
    }
  }

  document.getElementById('totalPrice').textContent = Formatting.formatRupiah(order.total || 0);

  // Payment Status
  const paymentStatusDisplay = document.getElementById('paymentStatusDisplay');
  paymentStatusDisplay.textContent = formatStatus(order.paymentStatus);
  paymentStatusDisplay.className = `status ${statusClass}`;

  // Payment Info (if paid)
  if (order.paymentStatus && (order.paymentStatus.toLowerCase() === 'settlement' || order.paymentStatus.toLowerCase() === 'paid')) {
    if (order.paymentMethod) {
      document.getElementById('paymentMethodRow').style.display = 'block';
      document.getElementById('paymentMethod').textContent = order.paymentMethod;
    }
    if (order.transactionId) {
      document.getElementById('transactionIdRow').style.display = 'block';
      document.getElementById('transactionId').textContent = order.transactionId;
    }
    if (order.paidAt) {
      document.getElementById('paidDateRow').style.display = 'block';
      document.getElementById('paidDate').textContent = Formatting.formatDate(order.paidAt);
    }
  }

  // Customer Info
  document.getElementById('customerName').textContent = order.customerName || userAuth.displayName || '-';
  document.getElementById('customerEmail').textContent = order.email || userAuth.email || '-';
  document.getElementById('customerPhone').textContent = order.whatsapp || order.phone || '-';

  // Show content
  document.getElementById('detailContent').style.display = 'block';
}

// ============================================================================
// DISPLAY ADDONS
// ============================================================================

function displayAddons(addons) {
  const container = document.getElementById('addonsContainer');
  const noAddons = document.getElementById('noAddons');

  if (!addons || (Array.isArray(addons) && addons.length === 0)) {
    container.innerHTML = '<p class="text-muted">Tidak ada layanan tambahan</p>';
    return;
  }

  // If addons is a string, parse it
  let addonArray = addons;
  if (typeof addons === 'string') {
    if (addons.includes(',')) {
      addonArray = addons.split(',').map(a => a.trim());
    } else {
      addonArray = [addons];
    }
  }

  // Map addon names to prices (from config)
  const addonPrices = {
    'SSL': 0, // Free
    'Email': 50000,
    'CDN': 100000
  };

  let html = '';
  addonArray.forEach(addon => {
    const price = addonPrices[addon] || 0;
    html += `
      <div class="addon-item">
        <span class="addon-name">${addon}</span>
        <span class="addon-price">${Formatting.formatRupiah(price)}</span>
      </div>
    `;
  });

  container.innerHTML = html;
}

// ============================================================================
// UI STATES
// ============================================================================

function showLoadingState() {
  document.getElementById('loadingState').style.display = 'block';
  document.getElementById('detailContent').style.display = 'none';
  document.getElementById('errorState').style.display = 'none';
}

function hideLoadingState() {
  document.getElementById('loadingState').style.display = 'none';
}

function showErrorState(message = 'Pesanan tidak ditemukan') {
  document.getElementById('loadingState').style.display = 'none';
  document.getElementById('detailContent').style.display = 'none';
  document.getElementById('errorState').style.display = 'block';
  document.getElementById('errorMessage').textContent = message;
}

// ============================================================================
// ACTION BUTTONS
// ============================================================================

function printOrderDetail() {
  window.print();
}

function downloadOrderPDF() {
  Notifications.showToast('Fitur download PDF akan segera tersedia', 'info');
}

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

function getStatusClass(status) {
  const s = status.toLowerCase();
  if (s === 'settlement' || s === 'paid') return 'settlement';
  if (s === 'pending') return 'pending';
  if (s === 'expired') return 'expired';
  if (s === 'denied') return 'denied';
  return 'pending';
}

function formatStatus(status) {
  const s = status.toLowerCase();
  if (s === 'settlement' || s === 'paid') return 'Terbayar';
  if (s === 'pending') return 'Pending';
  if (s === 'expired') return 'Kadaluarsa';
  if (s === 'denied') return 'Ditolak';
  return status;
}

// formatDate, formatDateWithTime, formatRupiah, and showToast moved to centralized utilities
// Use Formatting.formatDate(), Formatting.formatRupiah(), and Notifications.showToast() instead

function logout() {
  if (confirm('Apakah Anda yakin ingin logout?')) {
    sessionStorage.removeItem('userAuth');
    userAuth = null;
    window.location.href = '/';
  }
}

// Export for global use
window.printOrderDetail = printOrderDetail;
window.downloadOrderPDF = downloadOrderPDF;
window.logout = logout;
